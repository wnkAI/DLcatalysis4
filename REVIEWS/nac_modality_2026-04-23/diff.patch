+    act_fn: relu
+    hidden_dim: 256
+    norm_fn: layer
+    num_layers: 4
+train:
+  batch_size: 10
+  max_epochs: 100
+  min_epochs: 20
+  earlystrop_patience: 25
+  grad_accum: 2
+  precision: bf16-mixed
+  seed: 42
+  valid_freq: 1.0
+  n_cpus: 8
+  n_gpu:
+  - 0
+  device: cuda
+  checkpoint_path: train/ckpt_ablation/v4_ultimate_A0_seq
+  log_path: train/log_ablation/v4_ultimate_A0_seq
